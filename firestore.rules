rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSiteAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == "cosnametech@gmail.com";
    }

    function validContactMessage() {
      return request.resource.data.firstName is string
        && request.resource.data.firstName.size() > 0
        && request.resource.data.firstName.size() < 200
        && request.resource.data.lastName is string
        && request.resource.data.lastName.size() < 200
        && request.resource.data.phone is string
        && request.resource.data.phone.size() > 0
        && request.resource.data.phone.size() < 80
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() < 12000
        && request.resource.data.read == false
        && request.resource.data.createdAt == request.time;
    }

    match /contact_messages/{docId} {
      allow create: if validContactMessage();
      allow read: if isSiteAdmin();
      allow update: if isSiteAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["read"])
        && request.resource.data.read is bool;
      allow delete: if isSiteAdmin();
    }

    match /contact_rate_limits/{emailKey} {
      allow read: if true;
      allow create: if request.resource.data.count == 1
        && request.resource.data.dayKey is string
        && request.resource.data.dayKey.size() == 10;
      allow update: if request.resource.data.count is int
        && request.resource.data.count >= 1
        && request.resource.data.count <= 2
        && request.resource.data.dayKey is string
        && request.resource.data.dayKey.size() == 10;
      allow delete: if false;
    }

    match /newsletter_subscribers/{docId} {
      allow create: if request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320
        && request.resource.data.subscribedAt == request.time;
      allow read: if isSiteAdmin();
    }
  }
}
